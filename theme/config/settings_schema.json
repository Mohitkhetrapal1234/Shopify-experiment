[
  {
    "name": "theme_info",
    "theme_name": "Atelier Vastra",
    "theme_version": "0.1.0",
    "theme_author": "Local build",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "text",
        "id": "brand_name",
        "label": "Brand name",
        "default": "Zariya"
      },
      {
        "type": "text",
        "id": "brand_kicker",
        "label": "Brand kicker",
        "default": "Modern heirlooms for celebration"
      },
      {
        "type": "color",
        "id": "background_color",
        "default": "#f5efe8",
        "label": "Background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#201614",
        "label": "Foreground"
      },
      {
        "type": "color",
        "id": "accent_color",
        "default": "#9a6c3c",
        "label": "Accent"
      },
      {
        "type": "color",
        "id": "surface_color",
        "default": "#e6d6c6",
        "label": "Surface"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "Input corner radius",
        "default": 4
      }
    ]
  }
]
