<header>
  <div class="header__brand">
    <h2 class="header__title">
      {{ settings.brand_name | default: shop.name | link_to: routes.root_url }}
    </h2>
  </div>

  <div class="header__menu">
    {% for link in section.settings.menu.links %}
      {{ link.title | link_to: link.url }}
    {% endfor %}
  </div>

  <div class="header__icons">
    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a href="{{ routes.cart_url }}">
      {% if cart.item_count > 0 %}
        <sup>{{ cart.item_count }}</sup>
      {% endif %}

      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

{% stylesheet %}
  header {
    min-height: 4.75rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 1.4rem;
    padding: 0.95rem 0;
    border-bottom: 1px solid rgba(26, 23, 21, 0.08);
    background: #fcfaf6;
  }

  .header__brand {
    justify-self: start;
  }

  .header__title {
    font-size: clamp(1.9rem, 2.1vw, 2.4rem);
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Garamond, Georgia, serif;
    letter-spacing: -0.04em;
    line-height: 0.9;
  }

  header a {
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  header a sup {
    position: absolute;
    left: 100%;
    overflow: hidden;
    max-width: var(--page-margin);
  }
  header svg {
    width: 2rem;
  }
  header .header__menu,
  header .header__icons {
    display: flex;
    gap: 1.15rem;
  }

  .header__menu {
    align-items: center;
    justify-self: center;
    justify-content: center;
  }

  .header__menu a {
    font-size: 0.92rem;
    letter-spacing: 0;
    text-transform: none;
    font-weight: 400;
    white-space: nowrap;
    opacity: 0.92;
  }

  .header__icons {
    justify-self: end;
    align-items: center;
  }

  .header__icons a,
  .header__icons shopify-account {
    color: var(--color-foreground);
  }

  .header__icons svg {
    width: 1.28rem;
    height: 1.28rem;
  }

  @media (max-width: 860px) {
    header {
      grid-template-columns: 1fr;
      gap: 0.7rem;
      padding: 0.9rem 0;
    }

    .header__brand,
    .header__menu,
    .header__icons {
      justify-self: start;
    }

    .header__menu {
      flex-wrap: wrap;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
