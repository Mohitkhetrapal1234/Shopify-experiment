<section class="zariya-home full-width">
  <div class="zariya-home__announce" aria-label="Store announcement">
    <div class="zariya-home__announce-track">
      <span>&lsaquo;</span>
      <span>Free shipping on orders over Rs. 25,000</span>
      <span>&rsaquo;</span>
    </div>
  </div>

  <div class="zariya-home__hero zariya-reveal" data-reveal>
    <article class="zariya-home__hero-panel zariya-home__hero-panel--left">
      <div class="zariya-home__hero-copy">
        <h1>{{ section.settings.heading }}</h1>
        <a class="zariya-home__hero-button" href="{{ section.settings.secondary_link | default: routes.all_products_collection_url }}">
          {{ section.settings.secondary_label }}
        </a>
      </div>
    </article>

    <article class="zariya-home__hero-panel zariya-home__hero-panel--right">
      <div class="zariya-home__hero-copy">
        <h2>Bridal, festive, and evening wardrobes composed with restraint.</h2>
        <a class="zariya-home__hero-button" href="{{ section.settings.primary_link | default: routes.collections_url }}">
          {{ section.settings.primary_label }}
        </a>
      </div>
    </article>
  </div>

  <div class="zariya-home__sale-strip">
    <div class="zariya-home__sale-strip-track">
      <span>Shop the sale</span>
      <span>End of season sale</span>
      <span>Shop the sale</span>
      <span>End of season sale</span>
      <span>Shop the sale</span>
      <span>End of season sale</span>
    </div>
  </div>

  <div class="zariya-home__philosophy zariya-reveal" data-reveal>
    <p class="zariya-home__kicker">Our philosophy</p>
    <h2>{{ section.settings.description }}</h2>
    <a class="zariya-home__text-link" href="{{ routes.root_url }}">Read more</a>
  </div>

  <div class="zariya-home__rail-header zariya-reveal" data-reveal>
    <h3>Find the perfect piece</h3>
  </div>

  <div class="zariya-home__collection-rail zariya-reveal" data-reveal>
    <article class="zariya-home__rail-card zariya-home__rail-card--one">
      <div class="zariya-home__rail-caption">
        <span>Lehengas</span>
        <span>&rarr;</span>
      </div>
    </article>
    <article class="zariya-home__rail-card zariya-home__rail-card--two">
      <div class="zariya-home__rail-caption">
        <span>Sarees</span>
        <span>&rarr;</span>
      </div>
    </article>
    <article class="zariya-home__rail-card zariya-home__rail-card--three">
      <div class="zariya-home__rail-caption">
        <span>Anarkalis</span>
        <span>&rarr;</span>
      </div>
    </article>
    <article class="zariya-home__rail-card zariya-home__rail-card--four">
      <div class="zariya-home__rail-caption">
        <span>Sharara Sets</span>
        <span>&rarr;</span>
      </div>
    </article>
  </div>

  <div class="zariya-home__promo-band zariya-reveal" data-reveal>
    <p>Get it before it's gone</p>
    <p>Lehengas</p>
    <p>Sarees</p>
    <p>Anarkalis</p>
    <a href="{{ routes.collections_url }}">Shop now</a>
  </div>

  <div class="zariya-home__feature zariya-reveal" data-reveal>
    <div class="zariya-home__feature-image">
      <div class="zariya-home__feature-copy">
        <p class="zariya-home__kicker">Festive edit</p>
        <h2>Reception-ready sequins and fluid drape sarees.</h2>
        <p>Offer virtual styling for bridal wardrobes and festive edits.</p>
      </div>
    </div>
  </div>

  <div class="zariya-home__gallery-header zariya-reveal" data-reveal>
    <a class="zariya-home__text-link" href="{{ routes.all_products_collection_url }}">Shop all</a>
  </div>

  <div class="zariya-home__gallery zariya-reveal" data-reveal>
    <article class="zariya-home__gallery-card zariya-home__gallery-card--one">
      <div class="zariya-home__rail-caption">
        <span>Wedding trousseau</span>
        <span>&rarr;</span>
      </div>
    </article>
    <article class="zariya-home__gallery-card zariya-home__gallery-card--two">
      <div class="zariya-home__rail-caption">
        <span>Festive signatures</span>
        <span>&rarr;</span>
      </div>
    </article>
    <article class="zariya-home__gallery-card zariya-home__gallery-card--three">
      <div class="zariya-home__rail-caption">
        <span>Craftsmanship</span>
        <span>&rarr;</span>
      </div>
    </article>
  </div>
</section>

{% stylesheet %}
  .zariya-home {
    --page-bg: #f8f5ef;
    --promo-bg: #f9efb2;
    --ink: #1a1715;
    --muted: #5f5954;
    --dark-bar: #292727;
    background: var(--page-bg);
    color: var(--ink);
    padding-bottom: 7rem;
  }

  .zariya-home__announce {
    background: var(--promo-bg);
    border-bottom: 1px solid rgba(26, 23, 21, 0.08);
    padding: 0.35rem 0;
  }

  .zariya-home__announce-track {
    display: flex;
    justify-content: center;
    gap: 2.2rem;
    font-size: 0.64rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    white-space: nowrap;
  }

  .zariya-home__hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 0;
  }

  .zariya-home__hero-panel {
    position: relative;
    min-height: 31.5rem;
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    overflow: hidden;
    will-change: transform;
    transition: transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .zariya-home__hero-panel::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(17, 15, 14, 0.1), rgba(17, 15, 14, 0.22));
  }

  .zariya-home__hero-panel:hover,
  .zariya-home__rail-card:hover,
  .zariya-home__gallery-card:hover,
  .zariya-home__feature-image:hover {
    transform: translateY(-0.2rem);
  }

  .zariya-home__hero-panel--left {
    background-image: url("https://images.unsplash.com/photo-1756483492198-8ca91227489b?auto=format&fit=crop&fm=jpg&q=80&w=1800");
  }

  .zariya-home__hero-panel--right {
    background-image: url("https://images.unsplash.com/photo-1756483488645-5973a1a92e33?auto=format&fit=crop&fm=jpg&q=80&w=1800");
  }

  .zariya-home__hero-copy {
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(78%, 32rem);
    transform: translate(-50%, -50%);
    z-index: 1;
    color: #fffaf4;
    text-align: center;
  }

  .zariya-home__kicker {
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: inherit;
    opacity: 0.86;
  }

  .zariya-home__hero-copy h1,
  .zariya-home__hero-copy h2,
  .zariya-home__philosophy h2,
  .zariya-home__rail-header h3,
  .zariya-home__feature-copy h2 {
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Garamond, Georgia, serif;
    font-weight: 400;
    letter-spacing: -0.045em;
  }

  .zariya-home__hero-copy h1,
  .zariya-home__hero-copy h2 {
    max-width: 10ch;
    margin: 0 auto;
    font-size: clamp(2.6rem, 4.8vw, 4rem);
    line-height: 0.95;
    text-wrap: balance;
  }

  .zariya-home__text-link {
    display: inline-block;
    margin-top: 1.15rem;
    padding-bottom: 0.15rem;
    border-bottom: 2px solid currentcolor;
    color: inherit;
    text-decoration: none;
    font-size: 0.76rem;
  }

  .zariya-home__hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.65rem;
    min-height: 2.35rem;
    padding: 0.7rem 1.35rem;
    background: var(--promo-bg);
    color: #26211d;
    text-decoration: none;
    font-size: 0.82rem;
  }

  .zariya-home__sale-strip {
    overflow: hidden;
    background: var(--dark-bar);
    color: #efe4cf;
    padding: 0.9rem 0;
  }

  .zariya-home__sale-strip-track {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    width: max-content;
    min-width: 100%;
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Garamond, Georgia, serif;
    font-size: 1rem;
    animation: zariya-sale-loop 24s linear infinite;
  }

  .zariya-home__sale-strip-track span {
    min-width: 14rem;
    text-align: center;
  }

  .zariya-home__philosophy,
  .zariya-home__rail-header,
  .zariya-home__gallery-header {
    padding: 5.4rem 3.2rem 0;
  }

  .zariya-home__philosophy h2 {
    max-width: 18ch;
    margin-top: 1.15rem;
    font-size: clamp(1.7rem, 3.7vw, 3.1rem);
    line-height: 1.1;
    text-wrap: balance;
  }

  .zariya-home__rail-header {
    display: flex;
    justify-content: space-between;
    align-items: end;
    border-top: 1px solid rgba(26, 23, 21, 0.14);
    margin: 5rem 3.2rem 0;
    padding: 1.45rem 0 0;
  }

  .zariya-home__rail-header h3 {
    font-size: clamp(1.5rem, 2.35vw, 2.15rem);
    line-height: 1.1;
  }

  .zariya-home__collection-rail,
  .zariya-home__gallery {
    display: grid;
    gap: 1rem;
    padding: 1.6rem 3.2rem 0;
  }

  .zariya-home__collection-rail {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .zariya-home__gallery {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    padding-top: 1.25rem;
  }

  .zariya-home__rail-card,
  .zariya-home__gallery-card {
    display: flex;
    align-items: end;
    min-height: 24rem;
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    overflow: hidden;
    will-change: transform, background-position;
    transition:
      transform 700ms cubic-bezier(0.22, 1, 0.36, 1),
      background-size 1200ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .zariya-home__rail-card:hover,
  .zariya-home__gallery-card:hover {
    background-size: 103%;
  }

  .zariya-home__rail-card--one {
    background-image: url("https://images.unsplash.com/photo-1756483510760-e03ca7fb36ae?auto=format&fit=crop&fm=jpg&q=80&w=1400");
  }

  .zariya-home__rail-card--two {
    background-image: url("https://images.unsplash.com/photo-1756483496981-05b741fdd40a?auto=format&fit=crop&fm=jpg&q=80&w=1400");
  }

  .zariya-home__rail-card--three {
    background-image: url("https://images.unsplash.com/photo-1756483510831-34a18c266b93?auto=format&fit=crop&fm=jpg&q=80&w=1400");
  }

  .zariya-home__rail-card--four {
    background-image: url("https://images.unsplash.com/photo-1756483510859-c0ab4c45782c?auto=format&fit=crop&fm=jpg&q=80&w=1400");
  }

  .zariya-home__gallery-card--one {
    background-image: url("https://images.unsplash.com/photo-1756483510760-e03ca7fb36ae?auto=format&fit=crop&fm=jpg&q=80&w=1600");
  }

  .zariya-home__gallery-card--two {
    background-image: url("https://images.unsplash.com/photo-1756483492198-8ca91227489b?auto=format&fit=crop&fm=jpg&q=80&w=1600");
  }

  .zariya-home__gallery-card--three {
    background-image: url("https://images.unsplash.com/photo-1754230778726-0a578ed2a7ac?auto=format&fit=crop&fm=jpg&q=80&w=1600");
  }

  .zariya-home__rail-caption {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1rem;
    background: var(--dark-bar);
    color: #f4ece0;
    font-size: 0.8rem;
  }

  .zariya-home__promo-band {
    display: grid;
    grid-template-columns: 1.1fr repeat(3, auto) auto;
    align-items: center;
    gap: 1.6rem;
    margin: 4.6rem 3.2rem 0;
    padding: 1.2rem 1.8rem;
    background: var(--promo-bg);
    color: var(--ink);
  }

  .zariya-home__promo-band p:first-child {
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Garamond, Georgia, serif;
    font-size: 1rem;
  }

  .zariya-home__promo-band p {
    font-size: 0.84rem;
  }

  .zariya-home__promo-band a {
    justify-self: end;
    background: var(--dark-bar);
    color: #f7f1e5;
    text-decoration: none;
    padding: 0.8rem 1.3rem;
    font-size: 0.78rem;
  }

  .zariya-home__feature {
    padding: 4.8rem 0 0;
  }

  .zariya-home__feature-image {
    position: relative;
    min-height: 27rem;
    background:
      linear-gradient(180deg, rgba(17, 15, 14, 0.06), rgba(17, 15, 14, 0.38)),
      url("https://images.unsplash.com/photo-1756483492198-8ca91227489b?auto=format&fit=crop&fm=jpg&q=80&w=2200");
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    transition:
      transform 700ms cubic-bezier(0.22, 1, 0.36, 1),
      background-size 1200ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .zariya-home__feature-image:hover {
    background-size: 103%;
  }

  .zariya-home__feature-copy {
    position: absolute;
    left: 2.4rem;
    bottom: 2.2rem;
    max-width: 31rem;
    color: #fffaf4;
  }

  .zariya-home__feature-copy h2 {
    margin-top: 0.45rem;
    font-size: clamp(1.8rem, 3.2vw, 2.85rem);
    line-height: 0.98;
    text-wrap: balance;
  }

  .zariya-home__feature-copy p:last-child {
    max-width: 24rem;
    margin-top: 0.8rem;
    font-size: 0.84rem;
  }

  .zariya-reveal {
    opacity: 0;
    transform: translateY(1.2rem);
    transition:
      opacity 900ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 900ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .zariya-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes zariya-ticker {
    0% {
      transform: translateX(0);
    }

    100% {
      transform: translateX(-12%);
    }
  }

  @keyframes zariya-sale-loop {
    0% {
      transform: translateX(0);
    }

    100% {
      transform: translateX(-16%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .zariya-home__announce-track,
    .zariya-home__sale-strip-track,
    .zariya-home__hero-panel,
    .zariya-home__rail-card,
    .zariya-home__gallery-card,
    .zariya-home__feature-image,
    .zariya-reveal {
      animation: none !important;
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
      background-size: cover !important;
    }
  }

  @media (max-width: 980px) {
    .zariya-home__hero,
    .zariya-home__collection-rail,
    .zariya-home__gallery,
    .zariya-home__promo-band {
      grid-template-columns: 1fr;
    }

    .zariya-home__hero-copy,
    .zariya-home__feature-copy,
    .zariya-home__philosophy,
    .zariya-home__rail-header,
    .zariya-home__gallery-header,
    .zariya-home__collection-rail,
    .zariya-home__gallery {
      padding-left: 1.4rem;
      padding-right: 1.4rem;
    }

    .zariya-home__rail-header {
      margin-left: 1.4rem;
      margin-right: 1.4rem;
    }

    .zariya-home__promo-band {
      margin-left: 1.4rem;
      margin-right: 1.4rem;
      padding: 1.2rem;
      gap: 0.8rem;
    }

    .zariya-home__hero-panel {
      min-height: 28rem;
    }

    .zariya-home__hero-copy h1,
    .zariya-home__hero-copy h2,
    .zariya-home__philosophy h2,
    .zariya-home__feature-copy h2 {
      max-width: none;
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .zariya-home__hero-copy {
      width: min(84%, 28rem);
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const section = document.currentScript?.closest('.shopify-section');
    if (!section) return;

    const items = section.querySelectorAll('[data-reveal]');
    if (!items.length) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) {
      items.forEach((item) => item.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      {
        threshold: 0.18,
        rootMargin: '0px 0px -8% 0px',
      }
    );

    items.forEach((item, index) => {
      item.style.transitionDelay = `${Math.min(index * 60, 180)}ms`;
      observer.observe(item);
    });
  })();
</script>

